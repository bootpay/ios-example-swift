// Bootpay 환경 설정 (예시)
//
// 사용법:
//   1. 이 파일을 `Bootpay.xcconfig`로 복사
//   2. 필요한 키만 주석 해제 + 값 채우기
//   3. Xcode → Project Settings → Configurations → Debug/Release에 Configuration File로 지정
//   4. pgTestSwift/Info.plist 에 아래 키들을 `$(BOOTPAY_*)` 변수 expansion으로 등록 (선택)
//
// 미설정 시 BootpayConfig.swift의 production 기본값으로 자동 fallback.
// `Bootpay.xcconfig`는 .gitignore 처리됨.

// 환경 스위치 (development | production)
BOOTPAY_ENV = production

// PG API - Application ID (iOS)
// BOOTPAY_APPLICATION_ID = 5b9f51264457636ab9a07cdd

// PG API - REST Application ID (EasyPay/REST 전용)
// BOOTPAY_REST_APPLICATION_ID = 59b731f084382614ebf72215

// PG API - Client/Server Key (권장)
// BOOTPAY_CLIENT_KEY = hxS-Up--5RvT6oU6QJE0JA
// BOOTPAY_SERVER_KEY = r5zxvDcQJiAP2PBQ0aJjSHQtblNmYFt6uFoEMhti_mg=

// Legacy PG API - Private Key (deprecated; 기존 코드 호환용)
// BOOTPAY_PRIVATE_KEY = WwDv0UjfwFa04wYG0LJZZv1xwraQnlhnHE375n52X0U=
